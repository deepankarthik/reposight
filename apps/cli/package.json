{
  "name": "repolens",
  "version": "0.1.1",
  "description": "Understand any codebase in minutes. Scans repositories, extracts architecture, and generates living documentation.",
  "type": "module",
  "main": "./dist/bundle.mjs",
  "bin": {
    "repolens": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deepankarthik/repolens.git"
  },
  "homepage": "https://github.com/deepankarthik/repolens",
  "bugs": {
    "url": "https://github.com/deepankarthik/repolens/issues"
  },
  "license": "MIT",
  "keywords": [
    "codebase",
    "architecture",
    "documentation",
    "code-analysis",
    "dependency-graph",
    "code-review",
    "onboarding",
    "living-docs"
  ],
  "scripts": {
    "build": "node ../../build-cli.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "node ../../build-cli.mjs && node ../../prepublish.mjs",
    "postpublish": "node ../../postpublish.mjs"
  },
  "dependencies": {
    "@repolens/shared": "workspace:*",
    "@repolens/context-engine": "workspace:*",
    "@repolens/ai": "workspace:*",
    "commander": "^12.1.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
