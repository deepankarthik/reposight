{
  "name": "reposight",
  "version": "0.1.3",
  "description": "Understand any codebase in minutes. Scans repositories, extracts architecture, and generates living documentation.",
  "type": "module",
  "main": "./dist/bundle.mjs",
  "bin": {
    "reposight": "./dist/bundle.mjs"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deepankarthik/reposight.git"
  },
  "homepage": "https://github.com/deepankarthik/reposight",
  "bugs": {
    "url": "https://github.com/deepankarthik/reposight/issues"
  },
  "license": "MIT",
  "keywords": [
    "codebase",
