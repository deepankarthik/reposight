{
  "name": "reposight",
  "version": "0.1.0",
  "private": true,
  "description": "Generate living documentation from codebases — architecture maps, dependency graphs, and data flow traces.",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,js,mjs,json,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,js,mjs,json,md}\"",
    "dev:cli": "pnpm --filter reposight dev",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.6"
  }
}
