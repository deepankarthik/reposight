# RepoLens Environment Configuration
# Copy to .env and fill in your values

# AI Provider Configuration (required for --summarize flag)
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=sk-your-api-key-here
AI_PROVIDER_MODEL=gpt-4o-mini

# Scanner Configuration (optional - defaults shown)
# MAX_CONTEXT_FILES=80
# MAX_CONTEXT_BYTES=120000
# MAX_FILE_BYTES=80000
# MAX_CHUNK_CHARS=6000

# Logging
LOG_LEVEL=info
